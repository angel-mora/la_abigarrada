<!DOCTYPE html>
<html>
  <head>
    <title>Panel Editorial — la abigarrada</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            fontFamily: {
              sans: ['DM Sans', 'sans-serif'],
              serif: ['Libre Baskerville', 'serif'],
              mono: ['JetBrains Mono', 'monospace'],
            },
          },
        },
      }
    </script>
    <script>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }

      function toggleDarkMode() {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.theme = 'light';
        } else {
          document.documentElement.classList.add('dark');
          localStorage.theme = 'dark';
        }
      }
    </script>
  </head>

  <body class="bg-[#FAFAF8] dark:bg-[#1A1A1A] font-sans text-[#1A1A1A] dark:text-[#FAFAF8] min-h-screen flex flex-col transition-colors duration-200">
    <nav class="sticky top-0 z-50 bg-[#FAFAF8] dark:bg-[#111] border-b-4 border-black dark:border-white px-4 py-3 transition-colors duration-200">
      <div class="max-w-[1400px] mx-auto flex justify-between items-center">
        <div class="flex items-center gap-6">
          <%= link_to root_path, class: "hover:-translate-y-0.5 transition-transform" do %>
            <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :sm, show_subline: true, line_style: :segments)) %>
          <% end %>
          <span class="bg-[#FBED21] text-black px-2 py-1 font-mono text-[0.6rem] font-bold uppercase tracking-widest border-2 border-black rotate-[-2deg]">
            Panel Editorial
          </span>
        </div>

        <div class="flex gap-6 items-center" style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 700; text-transform: uppercase;">
          <button onclick="toggleDarkMode()" class="relative flex items-center w-14 h-8 rounded-full border-2 border-black dark:border-white bg-gray-200 dark:bg-gray-800 transition-colors duration-300 focus:outline-none" aria-label="Toggle dark mode">
            <div class="absolute inset-0 flex justify-between items-center px-1 text-xs pointer-events-none z-10">
              <span>☀️</span>
              <span>🌙</span>
            </div>
            <div class="w-6 h-6 bg-white dark:bg-black border-2 border-black dark:border-white rounded-full transition-transform duration-300 transform translate-x-[2px] dark:translate-x-[26px] relative z-0"></div>
          </button>
          <%= link_to "Artículos", admin_articles_path, class: "text-black dark:text-white hover:underline" %>
          <%= link_to "Autores", admin_authors_path, class: "text-black dark:text-white hover:underline" %>
          <%= link_to "Ver Sitio", root_path, class: "bg-black dark:bg-white text-white dark:text-black px-4 py-2 border-2 border-black dark:border-white hover:bg-white hover:text-black dark:hover:bg-black dark:hover:text-white transition-colors shadow-[2px_2px_0px_#000] dark:shadow-[2px_2px_0px_#FFF] hover:shadow-none hover:translate-y-0.5 hover:translate-x-0.5" %>
          <%= button_to "Salir", session_path, method: :delete, class: "text-red-600 hover:underline" %>
        </div>
      </div>
    </nav>

    <main class="flex-grow w-full max-w-[1400px] mx-auto p-4 md:p-8">
      <% if notice %>
        <div class="bg-[#3DB34A] border-4 border-black dark:border-white text-black font-mono text-xs font-bold uppercase p-4 mb-8 shadow-[4px_4px_0px_#000] dark:shadow-[4px_4px_0px_#FFF]"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="bg-red-500 border-4 border-black dark:border-white text-white font-mono text-xs font-bold uppercase p-4 mb-8 shadow-[4px_4px_0px_#000] dark:shadow-[4px_4px_0px_#FFF]"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <%= render 'shared/footer' %>
  </body>
</html>
