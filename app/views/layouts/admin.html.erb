<!DOCTYPE html>
<html>
  <head>
    <title>Panel Editorial — la abigarrada</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    
    <script type="importmap">
      {
        "imports": {
          "trix": "https://unpkg.com/trix@2.1.1/dist/trix.umd.min.js",
          "@rails/actiontext": "https://unpkg.com/@rails/actiontext@8.0.5/app/javascript/actiontext/index.js"
        }
      }
    </script>
    <script type="module">
      import "trix"
      import "@rails/actiontext"
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['DM Sans', 'sans-serif'],
              serif: ['Libre Baskerville', 'serif'],
              mono: ['JetBrains Mono', 'monospace'],
            },
          },
        },
      }
    </script>
  </head>

  <body class="bg-[#FAFAF8] font-sans text-[#1A1A1A] min-h-screen flex flex-col">
    <nav class="sticky top-0 z-50 bg-[#FAFAF8] border-b-4 border-black px-4 py-3">
      <div class="max-w-[1400px] mx-auto flex justify-between items-center">
        <div class="flex items-center gap-6">
          <%= link_to root_path, class: "hover:-translate-y-0.5 transition-transform" do %>
            <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :sm, show_subline: true, line_style: :segments)) %>
          <% end %>
          <span class="bg-[#FBED21] text-black px-2 py-1 font-mono text-[0.6rem] font-bold uppercase tracking-widest border-2 border-black rotate-[-2deg]">
            Panel Editorial
          </span>
        </div>

        <div class="flex gap-6 items-center" style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 700; text-transform: uppercase;">
          <%= link_to "Artículos", admin_articles_path, class: "hover:underline" %>
          <%= link_to "Autores", admin_authors_path, class: "hover:underline" %>
          <%= link_to "Ver Sitio", root_path, class: "bg-black text-white px-4 py-2 border-2 border-black hover:bg-white hover:text-black transition-colors shadow-[2px_2px_0px_#000] hover:shadow-none hover:translate-y-0.5 hover:translate-x-0.5" %>
          <%= button_to "Salir", session_path, method: :delete, class: "text-red-600 hover:underline" %>
        </div>
      </div>
    </nav>

    <main class="flex-grow w-full max-w-[1400px] mx-auto p-4 md:p-8">
      <% if notice %>
        <div class="bg-[#3DB34A] border-4 border-black text-black font-mono text-xs font-bold uppercase p-4 mb-8 shadow-[4px_4px_0px_#000]"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="bg-red-500 border-4 border-black text-white font-mono text-xs font-bold uppercase p-4 mb-8 shadow-[4px_4px_0px_#000]"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="bg-[#FAFAF8] text-black py-20 px-4 border-t-4 border-black mt-auto">
      <div class="max-w-[1400px] mx-auto grid md:grid-cols-4 gap-12 border-b-4 border-black pb-16">
        <div class="md:col-span-2">
          <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :md, show_subline: true, line_style: :segments)) %>
          <p class="mt-8 text-xl font-black uppercase tracking-tight max-w-sm leading-none" style="font-family: 'DM Sans', sans-serif;">
            Laboratorio de pensamiento crítico latinoamericano.
          </p>
        </div>
        
        <div class="flex flex-col gap-4 font-mono text-sm font-bold uppercase tracking-widest">
          <span class="text-[#E21C21]">Navegación</span>
          <%= link_to "Inicio", root_path, class: "hover:underline hover:bg-black hover:text-white w-max" %>
          <%= link_to "Revista", articles_path, class: "hover:underline hover:bg-black hover:text-white w-max" %>
          <%= link_to "Manual Identidad", identity_manual_path, class: "hover:underline hover:bg-black hover:text-white w-max" %>
        </div>

        <div class="flex flex-col gap-4 font-mono text-sm font-bold uppercase tracking-widest">
          <span class="text-[#E21C21]">Redes</span>
          <%= link_to "Instagram", "#", class: "hover:underline hover:bg-black hover:text-white w-max" %>
          <%= link_to "X / Twitter", "#", class: "hover:underline hover:bg-black hover:text-white w-max" %>
          <%= link_to "Contacto", "#", class: "hover:underline hover:bg-black hover:text-white w-max" %>
        </div>
      </div>
      <div class="max-w-[1400px] mx-auto mt-6 flex justify-between items-center text-[0.6rem] font-bold uppercase tracking-[0.3em] font-mono">
        <span>la abigarrada © 2026</span>
        <span>Transmisión Abierta</span>
      </div>
    </footer>
  </body>
</html>
