<nav class="sticky top-0 z-50 bg-white/90 dark:bg-[#1A1A1A]/90 backdrop-blur-sm border-b border-black/10 dark:border-white/10 px-6 py-5 transition-colors duration-200">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <%= link_to root_path do %>
      <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :sm, show_subline: true, line_style: :segments)) %>
    <% end %>

    <div class="hidden lg:flex gap-10 items-center" style="font-family: 'DM Sans', sans-serif; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">
      <%= link_to "Observatorio", "#", class: "text-[#1A1A1A] dark:text-[#FAFAF8] hover:text-black/50 dark:hover:text-white/50 transition-colors" %>
      <%= link_to "Comunidad", "#", class: "text-[#1A1A1A] dark:text-[#FAFAF8] hover:text-black/50 dark:hover:text-white/50 transition-colors" %>
      <%= link_to "Revista", "#", class: "text-[#1A1A1A] dark:text-[#FAFAF8] hover:text-black/50 dark:hover:text-white/50 transition-colors" %>
      <%= link_to "Editorial", "#", class: "text-[#1A1A1A] dark:text-[#FAFAF8] hover:text-black/50 dark:hover:text-white/50 transition-colors" %>
      <%= link_to "Colaboraciones", "#", class: "text-[#1A1A1A] dark:text-[#FAFAF8] hover:text-black/50 dark:hover:text-white/50 transition-colors" %>
    </div>

    <div class="flex items-center gap-6">
      <button onclick="toggleDarkMode()" class="text-xl p-2 hover:bg-black/5 dark:hover:bg-white/5 rounded-full transition-colors" aria-label="Toggle dark mode">
        <span class="dark:hidden">🌙</span>
        <span class="hidden dark:inline">☀️</span>
      </button>
      <%= link_to "Suscríbete", "#", class: "px-5 py-2.5 bg-[#1A1A1A] dark:bg-[#FAFAF8] text-white dark:text-[#1A1A1A] text-[0.7rem] font-bold uppercase tracking-widest", style: "font-family: 'JetBrains Mono', monospace;" %>
    </div>
  </div>
</nav>

<main class="dark:bg-[#1A1A1A]">
  <%# Hero Section: Professional Blog Typography, No Logo %>
  <section class="relative flex flex-col items-center justify-center px-6 py-32 bg-white dark:bg-[#1A1A1A] transition-colors duration-200">
    <div class="relative z-10 text-center max-w-4xl">
      <h1 class="text-5xl md:text-7xl font-bold mb-8 leading-[1.1] text-[#1A1A1A] dark:text-[#FAFAF8] tracking-tight" style="font-family: 'DM Sans', sans-serif;">
        Identidades Múltiples.
      </h1>

      <p class="max-w-2xl mx-auto text-xl md:text-2xl text-[#444] dark:text-gray-300 leading-relaxed mb-12" style="font-family: 'Libre Baskerville', serif;">
        Un blog sobre lo que la modernidad no puede ordenar. La coexistencia de tiempos y culturas que se resisten a la síntesis.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-6">
        <%= link_to "#", class: "px-10 py-4 bg-[#1A1A1A] dark:bg-[#FAFAF8] text-white dark:text-[#1A1A1A] font-bold text-sm tracking-widest uppercase transition-colors hover:bg-[#333] dark:hover:bg-white", style: "font-family: 'JetBrains Mono', monospace;" do %>
          Explora los artículos
        <% end %>
      </div>
    </div>
  </section>

  <%# Manifiesto Section %>
  <section class="py-24 px-6 bg-[#FAFAF8] dark:bg-[#111] border-t border-black/10 dark:border-white/10 transition-colors duration-200">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-8 tracking-tight text-[#1A1A1A] dark:text-[#FAFAF8]" style="font-family: 'DM Sans', sans-serif;">Habitar la Contradicción.</h2>
      <p class="text-lg md:text-xl leading-[1.8] text-[#333] dark:text-gray-300" style="font-family: 'Libre Baskerville', serif;">
        No buscamos la armonía cómoda, sino la polifonía visual y política. Un espacio abigarrado para una realidad compleja.
      </p>
    </div>
  </section>

  <%# Blog Articles Preview (Standard Blog Grid) %>
  <section class="py-24 px-6 bg-white dark:bg-[#1A1A1A] border-t border-black/10 dark:border-white/10 transition-colors duration-200">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-2xl font-bold font-sans text-[#1A1A1A] dark:text-[#FAFAF8]">Últimos artículos</h2>
        <%= link_to "Ver todos →", "#", class: "text-sm font-bold font-mono tracking-widest uppercase hover:underline dark:text-gray-400" %>
      </div>

      <div class="grid md:grid-cols-3 gap-12">
        <% 3.times do |i| %>
          <article class="flex flex-col group cursor-pointer">
            <div class="h-48 bg-[#FAFAF8] dark:bg-[#222] border border-black/10 dark:border-white/10 mb-6 flex items-center justify-center p-8 transition-colors duration-200">
               <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :lg, show_subline: true, line_style: :segments)) %>
            </div>
            <div class="flex items-center gap-4 mb-4">
              <span class="text-[0.7rem] font-bold font-mono uppercase tracking-widest text-[#1A1A1A] dark:text-gray-400">Observatorio</span>
              <span class="text-[0.7rem] font-mono text-gray-500">Abril 15, 2026</span>
            </div>
            <h3 class="text-xl font-bold mb-3 font-sans text-[#1A1A1A] dark:text-[#FAFAF8] group-hover:underline">La crisis de la modernidad en el Sur Global</h3>
            <p class="text-sm leading-relaxed text-[#444] dark:text-gray-400 font-serif">
              Un análisis sobre cómo las estructuras políticas contemporáneas fallan en contener la diversidad de proyectos de vida...
            </p>
          </article>
        <% end %>
      </div>
    </div>
  </section>
</main>

<footer class="bg-[#1A1A1A] text-[#FAFAF8] py-20 px-6">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12">
    <div>
      <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :md, show_subline: true, dark_bg: true, line_style: :segments)) %>
      <p class="mt-6 text-[#FAFAF8]/50 max-w-xs text-sm leading-relaxed" style="font-family: 'Libre Baskerville', serif;">
        Laboratorio de pensamiento crítico, feminismos y observatorio antifascista de Latinoamérica.
      </p>
    </div>
    
    <div class="grid grid-cols-2 gap-16" style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;">
      <div class="flex flex-col gap-4">
        <span class="text-white/30">Navegación</span>
        <%= link_to "Inicio", root_path, class: "hover:text-white" %>
        <%= link_to "Manual", identity_manual_path, class: "hover:text-white" %>
      </div>
      <div class="flex flex-col gap-4">
        <span class="text-white/30">Contacto</span>
        <%= link_to "Email", "#", class: "hover:text-white" %>
        <%= link_to "Instagram", "#", class: "hover:text-white" %>
      </div>
    </div>
  </div>
  <div class="max-w-7xl mx-auto mt-20 pt-8 border-t border-white/10 flex justify-between items-center text-[0.65rem] text-white/30 uppercase tracking-widest" style="font-family: 'JetBrains Mono', monospace;">
    <span>la abigarrada © 2026</span>
    <span>v1.0</span>
  </div>
</footer>
