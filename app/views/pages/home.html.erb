<%= render 'shared/navbar' %>

<main class="dark:bg-[#111]">
  <%# BRUTALIST HERO (Manifesto Focus) %>
  <section class="relative px-4 py-20 md:py-32 bg-[#FAFAF8] dark:bg-[#111] overflow-hidden border-b-4 border-black dark:border-white transition-colors duration-200">
    <div class="max-w-[1400px] mx-auto grid md:grid-cols-12 gap-8 items-center">
      <div class="md:col-span-8 lg:col-span-9 relative z-10">
        <div class="inline-block bg-black text-white dark:bg-white dark:text-black px-4 py-2 mb-8 font-mono text-sm font-bold uppercase tracking-widest rotate-[-2deg] shadow-[4px_4px_0px_#E21C21]">
          Manifiesto v1.0
        </div>
        <h1 class="text-6xl md:text-[8rem] lg:text-[10rem] font-black leading-[0.85] text-black dark:text-white tracking-tighter uppercase" style="font-family: 'DM Sans', sans-serif;">
          Identidades <br/>
          <span class="text-transparent" style="-webkit-text-stroke: 2px currentColor;">múltiples.</span>
        </h1>
        <div class="mt-12 max-w-2xl border-l-8 border-[#E21C21] pl-6">
          <p class="text-2xl md:text-3xl text-black dark:text-gray-300 leading-snug" style="font-family: 'Libre Baskerville', serif;">
            Un laboratorio de pensamiento crítico, feminismos y observatorio antifascista de Latinoamérica.
          </p>
        </div>
      </div>
      
      <div class="md:col-span-4 lg:col-span-3 flex flex-col gap-6 relative z-10">
        <p class="text-lg text-black/70 dark:text-gray-400 font-mono uppercase tracking-widest leading-relaxed border-t-2 border-black dark:border-white pt-6">
          La modernidad occidental no nos puede ordenar.
        </p>
        <%= link_to articles_path, class: "group block px-8 py-6 bg-[#FBED21] text-black border-4 border-black font-bold text-xl uppercase tracking-widest hover:bg-black hover:text-white transition-all shadow-[8px_8px_0px_rgba(0,0,0,1)]", style: "font-family: 'DM Sans', sans-serif;" do %>
          Leer la Revista
          <span class="block mt-2 font-mono text-xs opacity-60 group-hover:opacity-100">Transmisión Abierta →</span>
        <% end %>
      </div>
    </div>
    
    <%# Background brutalist typography %>
    <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[200%] text-[25rem] font-black uppercase text-black/5 dark:text-white/5 whitespace-nowrap pointer-events-none select-none z-0" style="font-family: 'DM Sans', sans-serif;">
      LA ABIGARRADA
    </div>
  </section>

  <%# ASYMMETRIC GRID (Articles + Sections) %>
  <section class="bg-black dark:bg-white p-4 transition-colors duration-200">
    <div class="max-w-[1400px] mx-auto grid grid-cols-1 md:grid-cols-12 gap-4 auto-rows-min">
      
      <% if @latest_articles[0] %>
        <% article = @latest_articles[0] %>
        <% hover_bg = article.palette == "feminista" ? "#9B59B6" : (article.palette == "wiphala" ? "#F39A1E" : "#3DB34A") %>
        <article class="md:col-span-8 md:row-span-2 bg-[#FAFAF8] dark:bg-[#111] border-4 border-black dark:border-white p-8 md:p-12 flex flex-col justify-between group hover:bg-[<%= hover_bg %>] dark:hover:bg-[<%= hover_bg %>] transition-colors cursor-pointer relative overflow-hidden" onclick="window.location='<%= article_path(article) %>'">
          <% if article.featured_image.attached? %>
            <%= image_tag article.featured_image, class: "absolute inset-0 w-full h-full object-cover z-0 opacity-40 group-hover:opacity-20 transition-opacity" %>
          <% end %>
          <div class="flex justify-between items-start mb-16 relative z-10">
            <span class="bg-black text-white dark:bg-white dark:text-black px-3 py-1 font-mono text-xs uppercase font-bold tracking-widest"><%= article.palette %></span>
            <span class="font-mono text-xs font-bold text-black dark:text-white group-hover:text-black"><%= article.public_date&.strftime("%d %b %Y")&.upcase %></span>
          </div>
          <div class="relative z-10">
            <h2 class="text-5xl md:text-7xl font-black text-black dark:text-white group-hover:text-black leading-[0.9] tracking-tight mb-6" style="font-family: 'DM Sans', sans-serif;">
              <%= article.title %>
            </h2>
            <div class="text-xl text-black/80 dark:text-gray-300 group-hover:text-black/90 font-serif leading-relaxed max-w-3xl line-clamp-3">
              <%= strip_tags(article.content.to_s).truncate(200) %>
            </div>
          </div>
        </article>
      <% else %>
        <article class="md:col-span-8 md:row-span-2 bg-[#FAFAF8] dark:bg-[#111] border-4 border-black dark:border-white p-8 md:p-12 flex flex-col justify-between"></article>
      <% end %>

      <%# Newsletter CTA (Small block) %>
      <div id="newsletter" class="md:col-span-4 bg-[#E21C21] border-4 border-black dark:border-white p-8 flex flex-col justify-center text-black">
        <h3 class="text-3xl font-black mb-4 uppercase leading-none" style="font-family: 'DM Sans', sans-serif;">La señal en <br/>la tormenta.</h3>
        <p class="font-mono text-sm mb-6 font-bold">Recibe nuestras alertas antifascistas y nuevos textos directo en tu correo.</p>
        <%= form_with url: subscribers_path, class: "w-full" do |f| %>
          <%= f.email_field :email, placeholder: "TU CORREO AQUÍ", required: true, class: "w-full bg-[#FAFAF8] border-2 border-black p-3 mb-4 font-mono text-sm focus:outline-none focus:ring-4 focus:ring-black" %>
          <%= f.submit "Suscribir", class: "w-full bg-black text-white font-bold font-mono py-3 uppercase tracking-widest hover:bg-[#FAFAF8] hover:text-black transition-colors border-2 border-black cursor-pointer" %>
        <% end %>
      </div>

      <% if @latest_articles[1] %>
        <% article = @latest_articles[1] %>
        <% hover_bg = article.palette == "feminista" ? "#9B59B6" : (article.palette == "wiphala" ? "#F39A1E" : "#3DB34A") %>
        <article class="md:col-span-4 bg-[#FAFAF8] dark:bg-[#111] border-4 border-black dark:border-white p-8 flex flex-col group hover:bg-[<%= hover_bg %>] dark:hover:bg-[<%= hover_bg %>] transition-colors cursor-pointer relative overflow-hidden" onclick="window.location='<%= article_path(article) %>'">
          <% if article.featured_image.attached? %>
            <%= image_tag article.featured_image, class: "absolute inset-0 w-full h-full object-cover z-0 opacity-40 group-hover:opacity-20 transition-opacity" %>
          <% end %>
          <span class="relative z-10 self-start border-2 border-black dark:border-white text-black dark:text-white px-2 py-1 font-mono text-[0.6rem] uppercase font-bold tracking-widest mb-6 group-hover:border-black group-hover:text-black"><%= article.palette %></span>
          <h3 class="relative z-10 text-3xl font-bold text-black dark:text-white group-hover:text-black leading-tight mb-4" style="font-family: 'DM Sans', sans-serif;">
            <%= article.title %>
          </h3>
          <div class="relative z-10 text-black/70 dark:text-gray-400 group-hover:text-black/80 font-serif text-sm mt-auto line-clamp-2">
            <%= strip_tags(article.content.to_s).truncate(100) %>
          </div>
        </article>
      <% else %>
        <article class="md:col-span-4 bg-[#FAFAF8] dark:bg-[#111] border-4 border-black dark:border-white p-8 flex flex-col"></article>
      <% end %>

      <%# Info Block %>
      <div class="md:col-span-4 bg-[#9B59B6] border-4 border-black dark:border-white p-8 text-[#FAFAF8] flex flex-col justify-center">
        <div class="mb-4"><%= render(Logo::LogoComponent.new(palette: :wiphala, size: :lg, show_subline: true, line_style: :segments, dark_bg: true)) %></div>
        <p class="font-serif text-lg leading-snug">
          "No buscamos la armonía cómoda, sino la polifonía visual y política. Un espacio abigarrado para una realidad compleja."
        </p>
      </div>

      <% if @latest_articles[2] %>
        <% article = @latest_articles[2] %>
        <% hover_bg = article.palette == "feminista" ? "#9B59B6" : (article.palette == "wiphala" ? "#F39A1E" : "#2E3091") %>
        <article class="md:col-span-8 bg-[#FAFAF8] dark:bg-[#111] border-4 border-black dark:border-white p-8 flex flex-col group hover:bg-[<%= hover_bg %>] hover:text-white dark:hover:bg-[<%= hover_bg %>] transition-colors cursor-pointer relative overflow-hidden" onclick="window.location='<%= article_path(article) %>'">
          <% if article.featured_image.attached? %>
            <%= image_tag article.featured_image, class: "absolute inset-0 w-full h-full object-cover z-0 opacity-40 group-hover:opacity-20 transition-opacity" %>
          <% end %>
          <div class="flex justify-between items-start mb-8 relative z-10">
            <span class="text-black dark:text-white group-hover:text-white font-mono text-[0.6rem] uppercase font-bold tracking-widest"><%= article.palette %></span>
            <span class="text-black dark:text-white group-hover:text-white font-serif italic text-sm">Por <%= article.author.name %></span>
          </div>
          <h3 class="relative z-10 text-4xl md:text-5xl font-black text-black dark:text-white group-hover:text-white leading-[0.95] mb-4" style="font-family: 'DM Sans', sans-serif;">
            <%= article.title %>
          </h3>
          <div class="relative z-10 text-black/70 dark:text-gray-400 group-hover:text-white/80 font-serif mt-auto max-w-2xl line-clamp-2">
            <%= strip_tags(article.content.to_s).truncate(150) %>
          </div>
        </article>
      <% else %>
        <article class="md:col-span-8 bg-[#FAFAF8] dark:bg-[#111] border-4 border-black dark:border-white p-8 flex flex-col"></article>
      <% end %>

    </div>
  </section>
</main>

<%= render 'shared/footer' %>