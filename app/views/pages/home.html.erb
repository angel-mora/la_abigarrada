<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-black/5 px-6 py-4">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <%= link_to root_path do %>
      <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :sm, show_subline: true, line_style: :segments)) %>
    <% end %>

    <div class="hidden md:flex gap-8 items-center" style="font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em;">
      <%= link_to "Observatorio", "#", class: "hover:text-black/60 transition-colors" %>
      <%= link_to "Comunidad", "#", class: "hover:text-black/60 transition-colors" %>
      <%= link_to "Revista", "#", class: "hover:text-black/60 transition-colors" %>
      <%= link_to "Editorial", "#", class: "hover:text-black/60 transition-colors" %>
      <%= link_to "Colaboraciones", "#", class: "hover:text-black/60 transition-colors" %>
    </div>

    <div class="flex items-center gap-4">
      <%= link_to "Newsletter", "#", class: "px-4 py-2 bg-[#1A1A1A] text-white text-[0.75rem] font-bold uppercase tracking-wider", style: "font-family: 'JetBrains Mono', monospace;" %>
    </div>
  </div>
</nav>

<main>
  <%# Hero Section: Inspired by la_abigarrada_article.jpeg %>
  <section class="relative min-h-[80vh] flex flex-col items-center justify-center px-6 overflow-hidden bg-white">
    <%# Background grid tension / hairline elements %>
    <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 40px 40px;"></div>
    
    <div class="relative z-10 text-center max-w-5xl">
      <div class="mb-12 inline-block">
        <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :xl, show_subline: true, line_style: :segments)) %>
      </div>

      <h1 class="text-5xl md:text-8xl font-bold mb-8 leading-[1.1] text-[#1A1A1A] tracking-tighter" style="font-family: 'DM Sans', sans-serif;">
        Identidades Múltiples, <br/>
        <span class="italic text-black/40">Destinos Comunes.</span>
      </h1>

      <p class="max-w-2xl mx-auto text-xl md:text-2xl text-[#333] leading-relaxed mb-12" style="font-family: 'Libre Baskerville', serif;">
        Un laboratorio de pensamiento crítico, feminismos y observatorio antifascista. 
        Lo que la modernidad no puede ordenar, aquí encuentra su señal.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-6">
        <%= link_to "#", class: "group relative px-10 py-5 bg-[#1A1A1A] text-white font-bold text-lg transition-all" do %>
          <span class="relative z-10" style="font-family: 'JetBrains Mono', monospace;">Explora los artículos</span>
          <div class="absolute bottom-0 left-0 h-1 w-full flex">
            <% ["#E21C21", "#F39A1E", "#FBED21", "#3DB34A"].each do |c| %>
              <div style="flex: 1; background-color: <%= c %>;"></div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# Sections Grid (Observatorio, Comunidad, etc) %>
  <section class="py-24 bg-[#FAFAF8] border-t border-black/5 px-6">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-1">
      <% [
        { title: "Observatorio", desc: "Vigilancia y análisis técnico antifascista.", palette: :cmyk },
        { title: "Comunidad", desc: "Energía, lucha y colectividad feminista.", palette: :feminista },
        { title: "Revista", desc: "Pensamiento de largo aliento y narrativa viva.", palette: :wiphala },
        { title: "Editorial", desc: "La voz del proyecto y su posicionamiento.", palette: :rojinegra }
      ].each do |sec| %>
        <div class="bg-white p-10 flex flex-col justify-between hover:shadow-2xl transition-all border border-black/5 group">
          <div>
            <div class="mb-6">
              <%= render(Logo::LogoComponent.new(palette: sec[:palette], size: :sm, show_subline: true, line_style: :segments)) %>
            </div>
            <h3 class="text-2xl font-bold mb-4" style="font-family: 'DM Sans', sans-serif;"><%= sec[:title] %></h3>
            <p class="text-black/60 leading-relaxed" style="font-family: 'Libre Baskerville', serif;"><%= sec[:desc] %></p>
          </div>
          <div class="mt-8 flex items-center gap-2 text-[0.7rem] font-bold uppercase tracking-widest opacity-40 group-hover:opacity-100 transition-opacity" style="font-family: 'JetBrains Mono', monospace;">
            Ver sección <span>→</span>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# Manifiesto Section (Opción B) %>
  <section class="py-32 px-6 bg-white border-t border-black/5">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-12 tracking-tight" style="font-family: 'DM Sans', sans-serif;">Habitar la Contradicción.</h2>
      <div class="space-y-8 text-xl md:text-2xl leading-[1.8] text-[#222]" style="font-family: 'Libre Baskerville', serif;">
        <p>No buscamos la armonía cómoda, sino la polifonía visual y política. Un espacio abigarrado para una realidad compleja.</p>
        <p class="text-black/40 italic">"Una señal que se abre paso a través de la interferencia."</p>
      </div>
    </div>
  </section>
</main>

<footer class="bg-[#1A1A1A] text-white py-20 px-6">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12">
    <div>
      <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :md, show_subline: true, dark_bg: true, line_style: :segments)) %>
      <p class="mt-6 text-white/40 max-w-xs text-sm" style="font-family: 'Libre Baskerville', serif;">
        Laboratorio de pensamiento crítico y observatorio antifascista.
      </p>
    </div>
    
    <div class="grid grid-cols-2 gap-16" style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;">
      <div class="flex flex-col gap-4">
        <span class="text-white/30">Navegación</span>
        <%= link_to "Inicio", root_path, class: "hover:text-white/60" %>
        <%= link_to "Manual", identity_manual_path, class: "hover:text-white/60" %>
      </div>
      <div class="flex flex-col gap-4">
        <span class="text-white/30">Contacto</span>
        <%= link_to "Email", "#", class: "hover:text-white/60" %>
        <%= link_to "Instagram", "#", class: "hover:text-white/60" %>
      </div>
    </div>
  </div>
  <div class="max-w-7xl mx-auto mt-20 pt-8 border-t border-white/5 flex justify-between items-center text-[0.65rem] text-white/20 uppercase tracking-widest" style="font-family: 'JetBrains Mono', monospace;">
    <span>la abigarrada © 2026</span>
    <span>v1.0 — Transmisión Abierta</span>
  </div>
</footer>
