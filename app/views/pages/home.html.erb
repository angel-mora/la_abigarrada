<nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm border-b border-black/10 px-6 py-5">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <%= link_to root_path do %>
      <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :sm, show_subline: true, line_style: :segments)) %>
    <% end %>

    <div class="hidden lg:flex gap-10 items-center" style="font-family: 'DM Sans', sans-serif; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #1A1A1A;">
      <%= link_to "Observatorio", "#", class: "hover:text-black/50 transition-colors" %>
      <%= link_to "Comunidad", "#", class: "hover:text-black/50 transition-colors" %>
      <%= link_to "Revista", "#", class: "hover:text-black/50 transition-colors" %>
      <%= link_to "Editorial", "#", class: "hover:text-black/50 transition-colors" %>
      <%= link_to "Colaboraciones", "#", class: "hover:text-black/50 transition-colors" %>
    </div>

    <div class="flex items-center gap-6">
      <%= link_to "Suscríbete", "#", class: "px-5 py-2.5 bg-[#1A1A1A] text-white text-[0.7rem] font-bold uppercase tracking-widest", style: "font-family: 'JetBrains Mono', monospace;" %>
    </div>
  </div>
</nav>

<main>
  <%# Hero Section: High Contrast & Political Strength %>
  <section class="relative min-h-[90vh] flex flex-col items-center justify-center px-6 bg-white overflow-hidden">
    <%# Minimalist grid based on la_abigarrada_article.jpeg inspiration %>
    <div class="absolute inset-0 pointer-events-none opacity-[0.05]" style="background-image: linear-gradient(#000 0.5px, transparent 0.5px), linear-gradient(90deg, #000 0.5px, transparent 0.5px); background-size: 60px 60px;"></div>
    
    <div class="relative z-10 text-center max-w-6xl">
      <div class="mb-16">
        <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :xl, show_subline: true, line_style: :solid)) %>
      </div>

      <h1 class="text-6xl md:text-9xl font-extrabold mb-10 leading-[0.9] text-[#1A1A1A] tracking-tightest" style="font-family: 'DM Sans', sans-serif;">
        Identidades Múltiples,<br/>
        <span class="italic text-black/30 underline decoration-black/10">Una Señal de Resistencia.</span>
      </h1>

      <p class="max-w-3xl mx-auto text-2xl md:text-3xl text-[#222] leading-tight mb-16" style="font-family: 'Libre Baskerville', serif;">
        Feminismos y pensamiento crítico contra la barbarie. Donde la modernidad occidental fracasa en ordenar, nosotros habitamos la contradicción.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-8">
        <%= link_to "#", class: "group relative px-12 py-6 bg-[#1A1A1A] text-white font-bold text-xl transition-all hover:scale-[1.02]" do %>
          <span class="relative z-10" style="font-family: 'JetBrains Mono', monospace;">Explora la Revista</span>
          <div class="absolute bottom-0 left-0 h-1.5 w-full flex">
            <% ["#E21C21", "#F39A1E", "#FBED21", "#FFFFFF", "#3DB34A", "#2E3091", "#6E3B8E"].each do |c| %>
              <div style="flex: 1; background-color: <%= c %>;"></div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# Sections Grid: All sections with Wiphala only %>
  <section class="py-32 bg-[#FAFAF8] border-t border-black/10 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-2">
        <% [
          { title: "Observatorio", desc: "Vigilancia y análisis crítico frente al avance del fascismo en la región." },
          { title: "Comunidad", desc: "Red de afectos y organización colectiva desde los feminismos." },
          { title: "Revista", desc: "Narrativas de largo aliento que rompen la inmediatez del algoritmo." },
          { title: "Editorial", desc: "Posicionamiento político y ético sobre el presente latinoamericano." },
          { title: "Colaboraciones", desc: "Espacio abierto para voces disidentes y pensamiento abigarrado." }
        ].each do |sec| %>
          <div class="bg-white p-10 flex flex-col justify-between border border-black/5 hover:border-black/20 transition-all group">
            <div>
              <div class="mb-8">
                <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :sm, show_subline: true, line_style: :segments)) %>
              </div>
              <h3 class="text-2xl font-bold mb-6 tracking-tight" style="font-family: 'DM Sans', sans-serif;"><%= sec[:title] %></h3>
              <p class="text-black/70 leading-relaxed text-sm" style="font-family: 'Libre Baskerville', serif;"><%= sec[:desc] %></p>
            </div>
            <div class="mt-12 flex items-center gap-3 text-[0.7rem] font-bold uppercase tracking-widest text-black/30 group-hover:text-black transition-colors" style="font-family: 'JetBrains Mono', monospace;">
              Explorar <span>→</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# Manifiesto Section: Strengthened Copy %>
  <section class="py-40 px-6 bg-white border-t border-black/10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-5xl font-black mb-16 tracking-tighter uppercase" style="font-family: 'DM Sans', sans-serif;">Habitar la Contradicción.</h2>
      <div class="space-y-12 text-2xl md:text-3xl leading-[1.6] text-[#1A1A1A]" style="font-family: 'Libre Baskerville', serif;">
        <p>No buscamos la armonía cómoda del centro, sino la polifonía radical de los márgenes.</p>
        <p class="font-bold">"La abigarrada es una señal de radio en medio de la tormenta: urgente, profunda y colectiva."</p>
      </div>
    </div>
  </section>
</main>

<footer class="bg-[#1A1A1A] text-white py-24 px-6 border-t-[8px] border-black">
  <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-20">
    <div class="col-span-1">
      <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :md, show_subline: true, dark_bg: true, line_style: :segments)) %>
      <p class="mt-8 text-white/50 text-sm leading-relaxed" style="font-family: 'Libre Baskerville', serif;">
        Laboratorio de pensamiento crítico latinoamericano. <br/>
        Una señal que se abre paso a través de la interferencia.
      </p>
    </div>
    
    <div class="grid grid-cols-2 gap-12 text-[0.7rem] font-bold uppercase tracking-[0.2em]" style="font-family: 'JetBrains Mono', monospace;">
      <div class="flex flex-col gap-6">
        <span class="text-white/20">Secciones</span>
        <%= link_to "Observatorio", "#", class: "hover:text-white/50" %>
        <%= link_to "Comunidad", "#", class: "hover:text-white/50" %>
        <%= link_to "Revista", "#", class: "hover:text-white/50" %>
      </div>
      <div class="flex flex-col gap-6">
        <span class="text-white/20">Legal</span>
        <%= link_to "Privacidad", "#", class: "hover:text-white/50" %>
        <%= link_to "Identidad", identity_manual_path, class: "hover:text-white/50" %>
      </div>
    </div>

    <div class="flex flex-col gap-8">
      <span class="text-[0.7rem] font-bold uppercase tracking-[0.2em] text-white/20" style="font-family: 'JetBrains Mono', monospace;">Suscripción</span>
      <p class="text-sm text-white/40" style="font-family: 'Libre Baskerville', serif;">Recibe una notificación con cada nueva transmisión.</p>
      <%= link_to "Suscribirse al Newsletter", "#", class: "inline-block text-center py-4 border border-white/20 hover:bg-white hover:text-black transition-all font-bold text-[0.8rem]", style: "font-family: 'JetBrains Mono', monospace;" %>
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto mt-32 pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-[0.6rem] text-white/20 uppercase tracking-[0.3em]" style="font-family: 'JetBrains Mono', monospace;">
    <span>la abigarrada — v1.0.0 — 2026</span>
    <span>Latinoamérica Vive</span>
  </div>
</footer>
