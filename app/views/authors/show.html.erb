<nav class="sticky top-0 z-50 bg-[#FAFAF8] dark:bg-[#111] border-b-4 border-black dark:border-white px-4 py-3 transition-colors duration-200">
  <div class="max-w-[1400px] mx-auto flex justify-between items-center">
    <%= link_to root_path, class: "hover:-translate-y-0.5 transition-transform" do %>
      <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :sm, show_subline: true, line_style: :segments)) %>
    <% end %>

    <div class="hidden lg:flex gap-8 items-center" style="font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em;">
      <%= link_to "Observatorio", "#", class: "text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black px-2 py-1 transition-colors" %>
      <%= link_to "Comunidad", "#", class: "text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black px-2 py-1 transition-colors" %>
      <%= link_to "Revista", articles_path, class: "bg-black text-white dark:bg-white dark:text-black px-2 py-1" %>
      <%= link_to "Editorial", "#", class: "text-black dark:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black px-2 py-1 transition-colors" %>
    </div>

    <div class="flex items-center gap-4">
      <button onclick="toggleDarkMode()" class="text-2xl hover:scale-110 transition-transform" aria-label="Toggle dark mode">
        <span class="dark:hidden">🌙</span>
        <span class="hidden dark:inline">☀️</span>
      </button>
      <%= link_to "Suscríbete", "#", class: "px-6 py-2 bg-black dark:bg-white text-white dark:text-black text-[0.8rem] font-bold uppercase tracking-widest border-2 border-black dark:border-white hover:bg-[#E21C21] hover:text-black dark:hover:bg-[#E21C21] transition-colors shadow-[4px_4px_0px_rgba(0,0,0,1)]", style: "font-family: 'JetBrains Mono', monospace;" %>
    </div>
  </div>
</nav>

<main class="bg-black dark:bg-white p-4 min-h-screen transition-colors duration-200">
  <div class="max-w-[1400px] mx-auto">
    <div class="mb-8 bg-[#FAFAF8] dark:bg-[#111] border-4 border-black dark:border-white flex flex-col md:flex-row p-0">
      <% if @author.photo.attached? %>
        <div class="w-full md:w-1/3 flex-shrink-0 border-b-4 md:border-b-0 md:border-r-4 border-black dark:border-white">
          <%= image_tag @author.photo, class: "w-full h-full object-cover grayscale aspect-square" %>
        </div>
      <% end %>
      <div class="p-8 md:p-12 flex flex-col justify-center flex-grow">
        <h2 class="text-6xl md:text-8xl font-black uppercase tracking-tighter text-black dark:text-white mb-6" style="font-family: 'DM Sans', sans-serif;"><%= @author.name %></h2>
        <div class="prose prose-xl prose-black dark:prose-invert font-serif leading-relaxed">
          <p><%= @author.bio %></p>
        </div>
        <% if @author.cv.attached? %>
          <div class="mt-8">
            <%= link_to "Descargar CV →", rails_blob_path(@author.cv, disposition: "attachment"), class: "inline-block font-mono text-xs font-bold uppercase tracking-widest border-2 border-black dark:border-white px-6 py-2 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors text-black dark:text-white" %>
          </div>
        <% end %>
      </div>
    </div>

    <% if @articles.any? %>
      <div class="mt-16 mb-8 flex justify-between items-end gap-6">
        <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-[#FAFAF8] dark:text-[#1A1A1A]" style="font-family: 'DM Sans', sans-serif;">Artículos del autor</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @articles.each do |article| %>
          <% hover_bg = case article.palette
             when "feminista" then "#9B59B6"
             when "wiphala" then "#F39A1E"
             when "rojinegra" then "#E21C21"
             when "lgbtiq" then "#FBED21"
             when "cmyk" then "#00AEEF"
             else "#3DB34A"
             end %>
          <article class="bg-[#FAFAF8] dark:bg-[#111] border-4 border-black dark:border-white p-8 flex flex-col group hover:bg-[<%= hover_bg %>] dark:hover:bg-[<%= hover_bg %>] transition-colors cursor-pointer relative overflow-hidden h-[400px]" onclick="window.location='<%= article_path(article) %>'">
            <% if article.featured_image.attached? %>
              <%= image_tag article.featured_image, class: "absolute inset-0 w-full h-full object-cover z-0 opacity-20 group-hover:opacity-10 transition-opacity" %>
            <% end %>
            
            <div class="relative z-10 flex justify-between items-start mb-12">
              <span class="bg-black text-white dark:bg-white dark:text-black px-2 py-1 font-mono text-[0.6rem] uppercase font-bold tracking-widest"><%= article.palette %></span>
              <span class="font-mono text-[0.6rem] font-bold text-black dark:text-white group-hover:text-black"><%= article.public_date&.strftime("%d %b %Y")&.upcase %></span>
            </div>

            <div class="relative z-10 mt-auto">
              <h3 class="text-3xl font-black text-black dark:text-white group-hover:text-black leading-[0.95] mb-4" style="font-family: 'DM Sans', sans-serif;">
                <%= article.title %>
              </h3>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>
    
  </div>
</main>

<footer class="bg-[#FAFAF8] dark:bg-[#111] text-black dark:text-white py-20 px-4 border-t-4 border-black dark:border-white transition-colors duration-200">
  <div class="max-w-[1400px] mx-auto grid md:grid-cols-4 gap-12 border-b-4 border-black dark:border-white pb-16">
    <div class="md:col-span-2">
      <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :md, show_subline: true, line_style: :segments)) %>
      <p class="mt-8 text-xl font-black uppercase tracking-tight max-w-sm leading-none" style="font-family: 'DM Sans', sans-serif;">
        Laboratorio de pensamiento crítico latinoamericano.
      </p>
    </div>
    
    <div class="flex flex-col gap-4 font-mono text-sm font-bold uppercase tracking-widest">
      <span class="text-[#E21C21]">Navegación</span>
      <%= link_to "Inicio", root_path, class: "hover:underline hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black w-max" %>
      <%= link_to "Revista", articles_path, class: "hover:underline hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black w-max" %>
      <%= link_to "Manual Identidad", identity_manual_path, class: "hover:underline hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black w-max" %>
    </div>

    <div class="flex flex-col gap-4 font-mono text-sm font-bold uppercase tracking-widest">
      <span class="text-[#E21C21]">Redes</span>
      <%= link_to "Instagram", "#", class: "hover:underline hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black w-max" %>
      <%= link_to "X / Twitter", "#", class: "hover:underline hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black w-max" %>
      <%= link_to "Contacto", "#", class: "hover:underline hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black w-max" %>
    </div>
  </div>
  <div class="max-w-[1400px] mx-auto mt-6 flex justify-between items-center text-[0.6rem] font-bold uppercase tracking-[0.3em] font-mono">
    <span>la abigarrada © 2026</span>
    <span>Transmisión Abierta</span>
  </div>
</footer>