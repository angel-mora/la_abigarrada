<div class="flex justify-between items-center mb-12">
  <h2 class="text-4xl font-black uppercase tracking-tighter">Autores</h2>
  <%= link_to "Nuevo Autor", new_admin_author_path, class: "bg-black text-white px-6 py-3 font-bold uppercase text-sm tracking-widest shadow-[4px_4px_0px_#E21C21]" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <% @authors.each do |author| %>
    <div class="bg-white border-4 border-black p-8 flex justify-between items-center">
      <div>
        <h3 class="text-2xl font-black uppercase"><%= author.name %></h3>
        <p class="text-sm font-serif opacity-60"><%= author.bio.truncate(100) %></p>
      </div>
      <div class="flex gap-4">
        <%= link_to "Editar", edit_admin_author_path(author), class: "text-blue-600 font-bold text-xs uppercase" %>
        <%= button_to "Eliminar", admin_author_path(author), method: :delete, data: { confirm: "¿Estás seguro?" }, class: "text-red-600 font-bold text-xs uppercase" %>
      </div>
    </div>
  <% end %>
</div>
