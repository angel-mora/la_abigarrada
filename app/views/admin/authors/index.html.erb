<div class="flex justify-between items-center mb-12">
  <h2 class="text-4xl font-black uppercase tracking-tighter text-black dark:text-white">Autores</h2>
  <%= link_to "Nuevo Autor", new_admin_author_path, class: "bg-black dark:bg-white text-white dark:text-black px-6 py-3 font-bold uppercase text-sm tracking-widest shadow-[4px_4px_0px_#E21C21] dark:shadow-[4px_4px_0px_#FFF] hover:translate-y-1 hover:shadow-none transition-all" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <% @authors.each do |author| %>
    <div class="bg-white dark:bg-[#111] text-black dark:text-white border-4 border-black dark:border-white p-8 flex justify-between items-center">
      <div>
        <h3 class="text-2xl font-black uppercase"><%= author.name %></h3>
        <p class="text-sm font-serif opacity-60"><%= author.bio.truncate(100) %></p>
      </div>
      <div class="flex gap-4">
        <%= link_to "Editar", edit_admin_author_path(author), class: "text-blue-600 dark:text-blue-400 font-bold text-xs uppercase hover:underline" %>
        <%= button_to "Eliminar", admin_author_path(author), method: :delete, data: { confirm: "¿Estás seguro?" }, class: "text-red-600 dark:text-red-400 font-bold text-xs uppercase hover:underline" %>
      </div>
    </div>
  <% end %>
</div>
