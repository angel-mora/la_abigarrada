<%= form_with(model: [:admin, article], class: "space-y-10") do |f| %>
  <% if article.errors.any? %>
    <div class="bg-red-50 p-6 border-4 border-red-500 text-red-700">
      <h2 class="font-black uppercase text-sm tracking-widest mb-2"><%= pluralize(article.errors.count, "error") %> impiden guardar este artículo:</h2>
      <ul class="list-disc pl-5 font-mono text-xs">
        <% article.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-white p-8 border-4 border-black">
    <div class="space-y-6">
      <div>
        <%= f.label :title, "Título", class: "block font-black uppercase text-xs tracking-[0.2em] mb-2" %>
        <%= f.text_field :title, class: "w-full border-2 border-black p-4 font-serif text-xl focus:ring-4 focus:ring-[#E21C21] outline-none" %>
      </div>

      <div class="grid grid-cols-2 gap-6">
        <div>
          <%= f.label :author_id, "Autor", class: "block font-black uppercase text-xs tracking-[0.2em] mb-2" %>
          <div class="relative">
            <%= f.collection_select :author_id, Author.all, :id, :name, {}, class: "w-full border-2 border-black p-3 font-mono text-xs appearance-none bg-white rounded-none cursor-pointer" %>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-black">
              <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
          </div>
        </div>
        <div>
          <%= f.label :palette, "Paleta Visual", class: "block font-black uppercase text-xs tracking-[0.2em] mb-2" %>
          <div class="relative">
            <%= f.select :palette, Article.palettes.keys.map { |k| [k.humanize, k] }, {}, class: "w-full border-2 border-black p-3 font-mono text-xs appearance-none bg-white rounded-none cursor-pointer" %>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-black">
              <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
          </div>
        </div>
      </div>

      <div>
        <%= f.label :public_date, "Fecha de Publicación", class: "block font-black uppercase text-xs tracking-[0.2em] mb-2" %>
        <%= f.date_field :public_date, class: "w-full border-2 border-black p-3 font-mono text-xs" %>
      </div>

      <div>
        <%= f.label :featured_image, "Imagen Destacada", class: "block font-black uppercase text-xs tracking-[0.2em] mb-2" %>
        <%= f.file_field :featured_image, class: "w-full border-2 border-black p-3 font-mono text-xs bg-gray-50" %>
      </div>
    </div>

    <div class="space-y-6 border-l-2 border-black/10 pl-12">
      <div class="bg-[#FBED21] p-6 border-4 border-black shadow-[8px_8px_0px_#000]">
        <h4 class="font-black uppercase text-xs tracking-[0.2em] mb-4">Importación Técnica</h4>
        <%= f.label :docx_file, "Subir Documento (.docx)", class: "block font-bold text-xs mb-2" %>
        <%= f.file_field :docx_file, class: "w-full bg-white border-2 border-black p-2 font-mono text-[0.6rem]" %>
        <p class="mt-4 text-[0.6rem] font-mono text-black/60 italic leading-tight">
          Al subir un archivo, el contenido se convertirá automáticamente a HTML y reemplazará el texto actual en el editor.
        </p>
      </div>
      
      <div>
        <%= f.label :status, "Estado Editorial", class: "block font-black uppercase text-xs tracking-[0.2em] mb-2" %>
        <div class="relative">
          <%= f.select :status, Article.statuses.keys.map { |k| [k.humanize, k] }, {}, class: "w-full border-2 border-black p-3 font-mono text-xs appearance-none bg-white rounded-none cursor-pointer" %>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-black">
            <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white border-4 border-black p-8">
    <%= f.label :content, "Contenido del Artículo", class: "block font-black uppercase text-xs tracking-[0.2em] mb-4" %>
    <div class="prose prose-xl max-w-none">
      <%= f.rich_text_area :content, class: "min-h-[500px] border-2 border-black p-6 font-serif" %>
    </div>
  </div>

  <div class="flex justify-end gap-6 pb-20">
    <%= link_to "Cancelar", admin_articles_path, class: "px-8 py-4 font-bold uppercase text-xs tracking-widest border-2 border-black hover:bg-black hover:text-white transition-colors" %>
    <%= f.submit "Guardar Artículo", class: "px-12 py-4 bg-black text-white font-black uppercase text-xs tracking-[0.2em] shadow-[8px_8px_0px_#E21C21] hover:translate-y-1 hover:shadow-none transition-all cursor-pointer" %>
  </div>
<% end %>
