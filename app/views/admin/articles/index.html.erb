<%= render(Admin::PageHeaderComponent.new(
      title: "Artículos", 
      right_action: link_to("Nuevo Artículo", new_admin_article_path, class: "bg-black dark:bg-white text-white dark:text-black px-6 py-3 font-bold uppercase text-sm tracking-widest shadow-[4px_4px_0px_#E21C21] dark:shadow-[4px_4px_0px_#FFF] hover:translate-y-1 hover:shadow-none transition-all")
)) %>

<div class="overflow-x-auto bg-white dark:bg-[#111] border-4 border-black dark:border-white">
  <table class="w-full text-left text-black dark:text-white">
    <thead class="bg-gray-100 dark:bg-[#222] border-b-4 border-black dark:border-white">
      <tr>
        <th class="p-4 font-bold uppercase text-xs tracking-widest">Título</th>
        <th class="p-4 font-bold uppercase text-xs tracking-widest">Autor</th>
        <th class="p-4 font-bold uppercase text-xs tracking-widest">Estado</th>
        <th class="p-4 font-bold uppercase text-xs tracking-widest">Paleta</th>
        <th class="p-4 font-bold uppercase text-xs tracking-widest">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @articles.each do |article| %>
        <tr class="border-b-2 border-black/10 dark:border-white/10 hover:bg-gray-50 dark:hover:bg-white/5">
          <td class="p-4 font-serif"><%= article.title %></td>
          <td class="p-4 text-sm font-bold"><%= article.author.name %></td>
          <td class="p-4">
            <span class="px-2 py-1 text-[0.6rem] font-black uppercase tracking-widest <%= article.published? ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-100' : 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-100' %>">
              <%= article.status %>
            </span>
          </td>
          <td class="p-4">
            <span class="px-2 py-1 text-[0.6rem] font-black uppercase tracking-widest bg-gray-100 dark:bg-white/20">
              <%= article.palette %>
            </span>
          </td>
          <td class="p-4 flex gap-3">
            <%= link_to "Ver", article_path(article), target: "_blank", class: "text-black dark:text-white font-bold text-xs uppercase hover:underline" %>
            <%= link_to "Editar", edit_admin_article_path(article), class: "text-blue-600 dark:text-blue-400 font-bold text-xs uppercase hover:underline" %>
            <% if article.draft? %>
              <%= button_to "Publicar", publish_admin_article_path(article), method: :patch, class: "text-green-600 dark:text-green-400 font-bold text-xs uppercase hover:underline" %>
            <% else %>
              <%= button_to "Borrador", unpublish_admin_article_path(article), method: :patch, class: "text-orange-600 dark:text-orange-400 font-bold text-xs uppercase hover:underline" %>
            <% end %>
            <%= button_to "Eliminar", admin_article_path(article), method: :delete, data: { confirm: "¿Estás seguro?" }, class: "text-red-600 dark:text-red-400 font-bold text-xs uppercase hover:underline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
