<% 
  palette_colors = Logo::LogoComponent::PALETTES[@article.palette.to_sym]
  accent_color = palette_colors.first
%>

<nav class="sticky top-0 z-50 bg-[#FAFAF8]/90 dark:bg-[#111]/90 backdrop-blur-md border-b-2 border-black dark:border-white px-4 py-3 transition-colors duration-200">
  <div class="max-w-[1200px] mx-auto flex justify-between items-center">
    <%= link_to root_path do %>
      <%= render(Logo::LogoComponent.new(palette: @article.palette, size: :sm, show_subline: true, line_style: :segments)) %>
    <% end %>
    
    <div class="flex items-center gap-6">
       <button onclick="toggleDarkMode()" class="text-xl">🌙</button>
       <%= link_to "Archivo", articles_path, class: "font-mono text-xs font-bold uppercase tracking-widest border-2 border-black dark:border-white px-4 py-1 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors" %>
    </div>
  </div>
</nav>

<article class="bg-[#FAFAF8] dark:bg-[#111] transition-colors duration-200">
  <%# Header: Inspired by la_abigarrada_article.jpeg %>
  <header class="pt-20 pb-32 px-4 border-b-4 border-black dark:border-white">
    <div class="max-w-[1000px] mx-auto">
      <div class="flex items-center gap-4 mb-12">
        <span class="bg-black text-white dark:bg-white dark:text-black px-4 py-1 font-mono text-xs uppercase font-bold tracking-[0.2em]">
          <%= @article.palette %>
        </span>
        <span class="font-mono text-xs font-bold text-black/40 dark:text-white/40 uppercase">
          <%= @article.public_date&.strftime("%d %B, %Y")&.upcase %>
        </span>
      </div>

      <h1 class="text-6xl md:text-[6rem] font-black leading-[0.9] text-black dark:text-white tracking-tightest uppercase mb-16" style="font-family: 'DM Sans', sans-serif;">
        <%= @article.title %>
      </h1>

      <div class="flex flex-col md:flex-row justify-between items-end gap-12">
        <div class="flex items-center gap-6">
          <%= link_to author_path(@article.author), class: "group flex items-center gap-6" do %>
            <% if @article.author.photo.attached? %>
              <%= image_tag @article.author.photo, class: "w-20 h-20 grayscale border-4 border-black dark:border-white group-hover:grayscale-0 transition-all" %>
            <% else %>
              <div class="w-20 h-20 bg-black flex items-center justify-center border-4 border-black dark:border-white group-hover:bg-[#1A1A1A] transition-colors">
                 <%= render(Logo::ProfileIconComponent.new(palette: @article.palette, size: 64, dark_bg: true)) %>
              </div>
            <% end %>
            <div>
              <p class="font-mono text-[0.6rem] uppercase font-bold text-black/40 dark:text-white/40 tracking-widest mb-1">Escrito por</p>
              <p class="text-xl font-bold text-black dark:text-white underline decoration-4 decoration-[<%= accent_color %>] underline-offset-4 group-hover:text-black/80 dark:group-hover:text-white/80"><%= @article.author.name %></p>
            </div>
          <% end %>
        </div>

        <div class="flex gap-2">
          <% palette_colors.each do |c| %>
            <div class="w-8 h-8 border-2 border-black dark:border-white" style="background-color: <%= c %>;"></div>
          <% end %>
        </div>
      </div>
    </div>
  </header>

  <% if @article.featured_image.attached? %>
    <section class="w-full border-b-4 border-black dark:border-white">
      <%= image_tag @article.featured_image, class: "w-full h-[60vh] object-cover grayscale hover:grayscale-0 transition-all duration-700" %>
    </section>
  <% end %>

  <%# Content %>
  <main class="py-32 px-4">
    <div class="max-w-[800px] mx-auto">
      <div class="prose prose-2xl prose-black dark:prose-invert font-serif leading-relaxed first-letter:text-7xl first-letter:font-black first-letter:mr-3 first-letter:float-left first-letter:uppercase">
        <%= @article.content %>
      </div>
      
      <div class="mt-32 pt-16 border-t-4 border-black dark:border-white">
        <div class="bg-black text-white dark:bg-white dark:text-black p-12 shadow-[12px_12px_0px_<%= accent_color %>]">
          <h4 class="font-black text-2xl uppercase tracking-tighter mb-8" style="font-family: 'DM Sans', sans-serif;">Sobre el autor</h4>
          <div class="flex flex-col sm:flex-row gap-8 items-start">
            <% if @article.author.photo.attached? %>
              <%= image_tag @article.author.photo, class: "w-32 h-32 object-cover grayscale border-4 border-white dark:border-black flex-shrink-0" %>
            <% else %>
              <div class="w-32 h-32 bg-white dark:bg-black flex items-center justify-center border-4 border-white dark:border-black flex-shrink-0">
                 <%= render(Logo::ProfileIconComponent.new(palette: @article.palette, size: 96, dark_bg: false)) %>
              </div>
            <% end %>
            <div>
              <h5 class="text-xl font-bold font-sans uppercase mb-4"><%= link_to @article.author.name, author_path(@article.author), class: "hover:underline decoration-2 decoration-[#{accent_color}]" %></h5>
              <p class="text-lg leading-relaxed opacity-80 mb-6 font-serif"><%= @article.author.bio %></p>
              <div class="flex gap-4">
                <%= link_to "Ver Perfil →", author_path(@article.author), class: "inline-block font-mono text-xs font-bold uppercase tracking-widest border-2 border-white dark:border-black px-6 py-2 hover:bg-white hover:text-black dark:hover:bg-black dark:hover:text-white transition-colors" %>
                <% if @article.author.cv.attached? %>
                  <%= link_to "Descargar CV ↓", rails_blob_path(@article.author.cv, disposition: "attachment"), class: "inline-block font-mono text-xs font-bold uppercase tracking-widest border-2 border-white dark:border-black px-6 py-2 hover:bg-white hover:text-black dark:hover:bg-black dark:hover:text-white transition-colors" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</article>

<footer class="bg-black text-white py-20 px-4">
  <div class="max-w-[800px] mx-auto text-center">
    <div class="mb-12">
      <%= render(Logo::LogoComponent.new(palette: :wiphala, size: :md, show_subline: true, line_style: :segments, dark_bg: true)) %>
    </div>
    <p class="font-mono text-xs font-bold uppercase tracking-[0.4em] opacity-40">Fin de la Transmisión</p>
  </div>
</footer>
