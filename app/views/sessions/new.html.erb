<%= render 'shared/navbar' %>

<main class="min-h-[80vh] flex flex-col items-center justify-center p-4 dark:bg-[#111] transition-colors duration-200">
  <div class="w-full max-w-md bg-[#FAFAF8] dark:bg-[#111] border-4 border-black dark:border-white p-8 md:p-12 relative">
    <div class="absolute -top-4 -left-4 bg-[#FBED21] text-black px-4 py-1 font-mono text-xs font-bold uppercase tracking-widest border-2 border-black rotate-[-2deg]">
      Acceso Editorial
    </div>

    <h1 class="text-4xl md:text-5xl font-black text-black dark:text-white uppercase tracking-tighter mb-8 mt-4" style="font-family: 'DM Sans', sans-serif;">
      Iniciar Sesión
    </h1>

    <% if flash[:alert] %>
      <div class="bg-red-500 text-white font-mono text-xs font-bold uppercase tracking-widest p-4 border-4 border-black mb-8 shadow-[4px_4px_0px_rgba(0,0,0,1)]">
        <%= flash[:alert] %>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div class="bg-[#3DB34A] text-black font-mono text-xs font-bold uppercase tracking-widest p-4 border-4 border-black dark:border-white mb-8 shadow-[4px_4px_0px_rgba(0,0,0,1)] dark:shadow-[4px_4px_0px_rgba(255,255,255,1)]">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%= form_with url: session_path, class: "flex flex-col gap-6" do |form| %>
      <div class="flex flex-col gap-2">
        <%= form.label :email_address, "Correo Electrónico", class: "font-mono text-xs font-bold uppercase tracking-widest text-black dark:text-white" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "border-4 border-black dark:border-white p-4 font-mono text-sm bg-white dark:bg-black text-black dark:text-white focus:outline-none focus:ring-4 focus:ring-[#E21C21] transition-all" %>
      </div>

      <div class="flex flex-col gap-2">
        <div class="flex justify-between items-end">
          <%= form.label :password, "Contraseña", class: "font-mono text-xs font-bold uppercase tracking-widest text-black dark:text-white" %>
          <%= link_to "¿Olvidaste tu contraseña?", new_password_path, class: "font-mono text-[0.6rem] uppercase tracking-widest text-black/60 dark:text-white/60 hover:text-black dark:hover:text-white underline decoration-2 decoration-[#E21C21]" %>
        </div>
        <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "••••••••", maxlength: 72, class: "border-4 border-black dark:border-white p-4 font-mono text-sm bg-white dark:bg-black text-black dark:text-white focus:outline-none focus:ring-4 focus:ring-[#E21C21] transition-all" %>
      </div>

      <%= form.submit "Entrar al Panel", class: "mt-4 bg-black dark:bg-white text-white dark:text-black font-bold font-mono py-4 uppercase tracking-widest hover:bg-[#E21C21] hover:text-black dark:hover:bg-[#E21C21] transition-colors border-4 border-black dark:border-white shadow-[6px_6px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_rgba(255,255,255,1)] hover:translate-y-1 hover:translate-x-1 hover:shadow-none cursor-pointer" %>
    <% end %>
  </div>
</main>
